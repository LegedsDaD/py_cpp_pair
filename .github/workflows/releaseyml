name: release

on:
  workflow_dispatch:
    inputs:
      mode:
        description: "What to run: check only, or check + publish (trusted publishing)"
        required: true
        default: "check"
        type: choice
        options:
          - check
          - publish
      version:
        description: "Release version (e.g. 1.0.0). Required for publish."
        required: false
      release_notes:
        description: "GitHub Release notes (markdown). Used for publish."
        required: false

jobs:
  check:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: Build distributions
        run: |
          python -m pip install -U pip build twine
          python -m build
          python -m twine check dist/*

      - uses: actions/upload-artifact@v4
        with:
          name: dist
          path: dist/*

  publish:
    runs-on: ubuntu-latest
    needs: check
    if: ${{ github.event.inputs.mode == 'publish' }}
    permissions:
      contents: write
      id-token: write
    steps:
      - name: Validate inputs
        run: |
          if [ -z "${{ github.event.inputs.version }}" ]; then
            echo "Input 'version' is required when mode=publish (e.g. 1.0.0)." >&2
            exit 2
          fi

      - uses: actions/download-artifact@v4
        with:
          name: dist
          path: dist

      - name: Create GitHub release
        uses: softprops/action-gh-release@v2
        with:
          tag_name: v${{ github.event.inputs.version }}
          name: v${{ github.event.inputs.version }}
          body: ${{ github.event.inputs.release_notes }}
          files: dist/*

      - name: Publish to PyPI (Trusted Publishing)
        uses: pypa/gh-action-pypi-publish@release/v1
        with:
          packages-dir: dist
